vn-res:Diệp_Văn_Cương a vn-ont:Người ;
    rdfs:label "Diệp Văn Cương"@vi ;
    vn-ont:abstract """Diệp Văn Cương (葉文疆, 1862- 1929), tự Thọ Sơn, hiệu Yên Sa, bút hiệu Cuồng Sĩ; là nhà báo, nhà giáo Việt Nam ở đầu thế kỷ 20. Ông được Vương Hồng Sển xem là nhân vật đại diện nhóm trí thức lúc bấy giờ.

"""@vi ;
