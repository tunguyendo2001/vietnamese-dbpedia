vn-res:BHD a vn-ont:TổChức ;
    rdfs:label "BHD"@vi ;
    vn-ont:abstract "BHD là tên thường gọi của Công ty TNHH Bình Hạnh Đan, được thành lập năm 1996. Đây là một trong những công ty tư nhân đầu tiên tại Việt Nam hoạt động trong lĩnh vực truyền thông, phân phối, và hợp tác sản xuất các chương trình truyền hình và điện ảnh. Bắt đầu với con số 10 nhân viên lúc mới thành lập tại Hà Nội, hiện nay BHD đã có khoảng 200 nhân viên khắp Việt Nam."@vi ;
    vn-ont:category vn-res:Công_ty_Việt_Nam,
        vn-res:Công_ty_sản_xuất_phim_Việt_Nam,
        vn-res:Công_ty_sản_xuất_truyền_hình_Việt_Nam,
        vn-res:Pages_using_deprecated_image_syntax ;
    prov:wasDerivedFrom [ a prov:Entity ;
            prov:generatedAtTime "2025-09-25T11:53:40.480241"^^xsd:dateTime ;
            prov:wasAttributedTo <https://vi.wikipedia.org/wiki/BHD> ] .

vn-res:Big_C a vn-ont:TổChức ;
    rdfs:label "Big C"@vi ;
    vn-ont:abstract """Big C (tiếng Thái Lan: บิ๊กซี ซูเปอร์เซ็นเตอร์) là công ty điều hành các siêu thị và cửa hàng tiện lợi ở Đông Nam Á có trụ sở tại Bangkok, Thái Lan. Big C, vào năm 2016, là nhà điều hành hệ thống siêu thị lớn thứ hai của Thái Lan đi sau của Tesco Lotus. Họ có các hoạt động tại ba quốc gia, cụ thể là Thái Lan, Việt Nam và Lào. Big C và các công ty con đã điều hành 697 cửa hàng tại Thái Lan tính đến tháng 9 năm 2015. Công ty đã báo lãi ròng 38 triệu USD trong quý thứ ba kết thúc vào tháng 9 năm 2015, giảm 14,5% so với cùng kỳ năm ngoái.
Công ty được thành lập bởi Central Group năm 1993 và Big C mở cửa hàng đầu tiên của mình tại ngã tư Wong Sawang, Bangkok (Thái Lan), cổ phiếu Big C lần đầu tiên được niêm yết trên Sở giao dịch chứng khoán Thái Lan năm 1995.
Tại Việt Nam, sau 22 năm hoạt động trên thị trường, hệ thống Big C được tập đoàn mẹ Central Group chuyển đổi thương hiệu vào ngày 1/3/2021. Theo đó, 7 siêu thị Big C nằm trong các tòa nhà sẽ được đổi tên mới là Tops Market và 5 đại siêu thị Big C hoàn tất đổi tên thành GO!."""@vi ;
    vn-ont:category vn-res:Bài_viết_có_văn_bản_tiếng_Thái,
        vn-res:Bản_mẫu_webarchive_dùng_liên_kết_wayback,
        vn-res:Công_ty_Việt_Nam,
        vn-res:Công_ty_có_trụ_sở_tại_Băng_Cốc,
        vn-res:Cửa_hàng_tiện_ích,
        vn-res:Nguồn_CS1_có_chữ_Thái_th,
        vn-res:Nguồn_CS1_tiếng_Thái_th,
        vn-res:Nhãn_hiệu_Thái_Lan,
        vn-res:Siêu_thị_Thái_Lan,
        vn-res:Trang_đưa_đối_số_thừa_vào_bản_mẫu ;
    prov:wasDerivedFrom [ a prov:Entity ;
            prov:generatedAtTime "2025-09-25T11:53:40.480369"^^xsd:dateTime ;
            prov:wasAttributedTo <https://vi.wikipedia.org/wiki/Big_C> ] .

vn-res:Báo_Cao_Bằng a vn-ont:TổChức ;
    rdfs:label "Báo Cao Bằng"@vi ;
    vn-ont:abstract """Báo Cao Bằng (tiếng Anh: Cao Bang Newspaper) là cơ quan báo chí trực thuộc Ủy ban nhân dân tỉnh Cao Bằng.
Trụ sở của Đài đặt tại số 87 phố Bế Văn Đàn, phường Thục Phán, tỉnh Cao Bằng."""@vi ;
