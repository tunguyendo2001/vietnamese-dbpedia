vn-res:Kềm_Nghĩa a vn-ont:TổChức ;
    rdfs:label "Kềm Nghĩa"@vi ;
    vn-ont:abstract """Kềm Nghĩa là tên gọi tắt của Công ty Cổ phần Kềm Nghĩa, là một công ty Việt Nam chuyên sản xuất, kinh doanh các sản phẩm chăm sóc móng như kềm cắt móng và da, giũa móng, bấm móng, sơn móng... và các dịch vụ chăm sóc sắc đẹp.
Theo thống kê hiện nay các sản phẩm của Kềm Nghĩa chiếm 80% thị phần tại Việt Nam, được công nhận là thương hiệu quốc gia. Ngoài việc phân phối mạnh trong nước với mạng lưới 187 nhà phân phối đều 64 tỉnh thành, sản phẩm Kềm Nghĩa còn có mặt tại trên 25 nước trên thế giới. Hiện nay Kềm Nghĩa đã xây dựng được 3 nhà máy với tổng mặt bằng sản xuất là 20,000 mét vuông và đang xây dựng thêm 1 nhà máy mới, với sự đa dạng về sản phẩm, Kềm Nghĩa hiện có trên 100 các sản phẩm chăm sóc móng."""@vi ;
    vn-ont:category vn-res:Bài_có_liên_kết_hỏng,
        vn-res:Bài_viết_có_văn_phong_quảng_cáo,
        vn-res:Bộ_Công_Thương_Việt_Nam,
        vn-res:Công_ty_Việt_Nam,
        vn-res:Kềm_Nghĩa,
        vn-res:Nhãn_hiệu_Việt,
        vn-res:Pages_using_deprecated_image_syntax,
        vn-res:Trang_cần_được_biên_tập_lại ;
    prov:wasDerivedFrom [ a prov:Entity ;
            prov:generatedAtTime "2025-09-25T11:53:40.484157"^^xsd:dateTime ;
            prov:wasAttributedTo <https://vi.wikipedia.org/wiki/Kềm_Nghĩa> ] .

vn-res:Danh_sách_công_ty_Việt_Nam a vn-ont:TổChức ;
    rdfs:label "Danh sách công ty Việt Nam"@vi ;
    vn-ont:abstract """Nền kinh tế Việt Nam chủ yếu được định hình bởi Đảng Cộng sản Việt Nam với Kế hoạch 5 năm được thông qua trong Hội nghị thường kỳ của Ban Chấp hành Trung ương và Đại hội Đại biểu toàn quốc.
Ngành chế tạo, công nghệ thông tin và các ngành công nghiệp công nghệ cao hiện nay thiết lập nên một bộ phận lớn mạnh và phát triển nhanh chóng của nền kinh tế quốc dân. Mặc dù Việt Nam mới gia nhập ngành công nghiệp dầu khí ở mức tương đối nhưng đây hiện là nhà sản xuất dầu mỏ lớn thứ ba tại Đông Nam Á với tổng sản lượng năm 2011 là 318.000 thùng/ngày (tương đương 50.600 m³/ngày). Năm 2010, Việt Nam đứng thứ 8 trong số các nhà sản xuất dầu thô lớn nhất khu vực châu Á-Thái Bình Dương. 
Dưới đây là danh sách các công ty tiêu biểu ở Việt Nam, được phân loại theo chuẩn ICB (Industry Classification Benchmark)."""@vi ;
    vn-ont:category vn-res:Bài_viết_với_chủ_đề_có_độ_nổi_bật_không_rõ,
        vn-res:Bản_mẫu_webarchive_dùng_liên_kết_wayback,
        vn-res:Công_ty_Việt_Nam,
        vn-res:Danh_sách_công_ty_Việt_Nam,
        vn-res:Danh_sách_công_ty_theo_quốc_gia,
        vn-res:Kinh_doanh_ở_Việt_Nam,
        vn-res:Trang_sử_dụng_div_col_có_các_tham_số_không_rõ ;
