vn-res:Công_ty_trách_nhiệm_hữu_hạn_Manulife_Việt_Nam a vn-ont:TổChức ;
    rdfs:label "Công ty trách nhiệm hữu hạn Manulife Việt Nam"@vi ;
    vn-ont:abstract "Công ty trách nhiệm hữu hạn Manulife Việt Nam thành lập tại Việt Nam vào tháng 6 năm 1999. Công ty cung cấp các dịch vụ tài chính cho hơn 390.000 khách hàng thông qua mạng lưới 10.000 đại lý bảo hiểm chuyên nghiệp. Manulife Việt Nam đã được cấp phép hoạt động trong lĩnh vực kinh doanh quản lý quỹ và vốn đầu tư tại Việt Nam với 14 năm hoạt động. Tổng doanh thu phí bảo hiểm của công ty năm 2012 đạt 2.154 tỷ đồng."@vi ;
    vn-ont:category vn-res:Bài_có_liên_kết_hỏng,
        vn-res:Công_ty_Việt_Nam,
        vn-res:Công_ty_bảo_hiểm,
        vn-res:Công_ty_trách_nhiệm_hữu_hạn,
        vn-res:Khởi_đầu_năm_1999 ;
    prov:wasDerivedFrom [ a prov:Entity ;
