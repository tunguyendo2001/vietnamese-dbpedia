vn-res:Danh_sách_hãng_ghi_hình_Việt_Nam a vn-ont:TổChức ;
    rdfs:label "Danh sách hãng ghi hình Việt Nam"@vi ;
    vn-ont:abstract "Danh sách chưa hoàn chỉnh dưới đây bao trùm cả các lĩnh vực mở rộng của công việc ghi hình hay làm video cũng như các hãng, các công ty, đơn vị của Việt Nam chuyên sản xuất sản phẩm phim video phục vụ mục đích cá nhân, nội bộ hoặc mục đích thương mại. Ở đây bao gồm cả các doanh nghiệp lớn, có tiếng tăm lẫn các doanh nghiệp địa phương với quy mô nhỏ hơn và có những đóng góp nổi bật trong lĩnh vực quay phim ghi hình."@vi ;
