vn-res:Danh_sách_ngân_hàng_tại_Việt_Nam a vn-ont:TổChức ;
    rdfs:label "Danh sách ngân hàng tại Việt Nam"@vi ;
    vn-ont:abstract "Tại Việt Nam hiện có 38 ngân hàng trong nước, bao gồm Ngân hàng Nhà nước và ngân hàng thương mại cổ phần. Ngoài ra, còn có 2 ngân hàng liên doanh, 8 ngân hàng có 100% vốn đầu tư nước ngoài đang hoạt động độc lập và hơn 50 chi nhánh, hơn 50 văn phòng đại diện ngân hàng nước ngoài tại Việt Nam."@vi ;
