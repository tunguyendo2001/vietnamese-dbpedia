vn-res:Quilling_Card_công_ty a vn-ont:TổChức ;
    rdfs:label "Quilling Card (công ty)"@vi ;
    vn-ont:abstract "Quilling Card, LLC. là một doanh nghiệp tư nhân tại Hoa Kỳ và Việt Nam chuyên kinh doanh và sản xuất các sản phẩm làm từ giấy xoắn. Công ty do doanh nhân Hương Wolf và chồng thành lập năm 2012 tại Triển lãm Văn phòng phẩm Quốc gia Hoa Kỳ. Với 500 nhân công gồm những nghệ nhân khiếm thính, công ty hiện là nhà cung cấp thiệp giấy xoắn hàng đầu thế giới với lượng khách hàng trải dài trên nhiều quốc gia như Mỹ, Canada, Úc, Nhật Bản, Trung Quốc, Pháp, Anh và Chile. Quilling Card đang nắm giữ hai kỷ lục Guinness thế giới về \"bức tranh giấy xoắn lớn nhất thế giới\" và \"số lượng người cùng làm thiệp giấy xoắn thủ công trong cùng một thời điểm nhiều nhất thế giới\" cho bản sao của bức họa Đêm đầy sao của Vincent Van Gogh."@vi ;
    vn-ont:category vn-res:Công_ty_Mỹ,
        vn-res:Công_ty_Việt_Nam,
        vn-res:Công_ty_thành_lập_năm_2012,
        vn-res:Nguồn_CS1_tiếng_Anh_en ;
    prov:wasDerivedFrom [ a prov:Entity ;
            prov:generatedAtTime "2025-09-25T11:53:40.485164"^^xsd:dateTime ;
            prov:wasAttributedTo <https://vi.wikipedia.org/wiki/Quilling_Card_(công_ty)> ] .

vn-res:Suntory_PepsiCo_Việt_Nam a vn-ont:TổChức ;
    rdfs:label "Suntory PepsiCo Việt Nam"@vi ;
    vn-ont:abstract """Suntory PepsiCo Việt Nam (tên tiếng Anh: Suntory PepsiCo Vietnam Beverage Company) là một công ty nước giải khát tại Việt Nam.
Suntory PepsiCo Việt Nam được thành lập vào tháng 4 năm 2013, là liên doanh giữa PepsiCo Việt Nam và tập đoàn nước giải khát Suntory Holdings Limited.
Chính thức gia nhập vào thị trường Việt Nam vào năm 1995, thông qua hình thức liên minh chiến lược và có tên gọi chính thức là Suntory Pepsico, trải qua gần 25 năm hình thành và phát triển, đến nay Pepsi đã trở thành một trong số những thương hiệu dẫn đầu thị trường công nghiệp nước giải khát."""@vi ;
    vn-ont:category vn-res:Bài_viết_có_chú_thích_không_đầy_đủ,
        vn-res:Công_ty_Việt_Nam,
        vn-res:Lỗi_CS1_liên_kết_ngoài,
        vn-res:Sơ_khai_công_ty,
        vn-res:Trang_cần_được_biên_tập_lại,
        vn-res:Tất_cả_bài_viết_sơ_khai ;
    prov:wasDerivedFrom [ a prov:Entity ;
            prov:generatedAtTime "2025-09-25T11:53:40.485262"^^xsd:dateTime ;
            prov:wasAttributedTo <https://vi.wikipedia.org/wiki/Suntory_PepsiCo_Việt_Nam> ] .

vn-res:Thi_Sách a vn-ont:Người ;
    rdfs:label "Thi Sách"@vi ;
    vn-ont:abstract """Thi Sách (chữ Hán: 詩索, ? - 15 tháng 1 năm 40) hay Thi (tiếng Trung: 詩), là một nhân vật chính trị thời kỳ Bắc thuộc trong lịch sử Việt Nam. Ông được biết đến là chồng của Trưng Trắc, vị nữ thủ lĩnh ở Lĩnh Nam đã nổi dậy đánh lại Thái thú Tô Định và lên ngôi nữ vương trong một thời gian ngắn, trước khi bị Phục Ba tướng quân Mã Viện đánh bại.

"""@vi ;
    vn-ont:category vn-res:Bài_viết_có_văn_bản_tiếng_Trung_Quốc,
        vn-res:Bản_mẫu_webarchive_dùng_liên_kết_wayback,
