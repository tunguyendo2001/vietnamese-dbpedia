vn-res:Cao_Minh_nhà_may a vn-ont:TổChức ;
    rdfs:label "Cao Minh (nhà may)"@vi ;
    vn-ont:abstract "Nhà may Cao Minh là một thương hiệu nhà may veston cao cấp nổi tiếng lâu đời tại Việt Nam được sáng lập từ năm 1948 bởi nhà thiết kế Lý Minh. Nhà may được biết đến nhiều vì từng may áo vest cho nhiều nhân vật công chúng nổi bật như Đại tướng Võ Nguyên Giáp. Ông Lý Minh được nhà nước Việt Nam công nhân danh hiệu \"Nghệ nhân ngành may\" năm 1991. Thương hiệu nhà may Cao Minh hiện có chi nhánh tại Hà Nội và Thành phố Hồ Chí Minh."@vi ;
    vn-ont:category vn-res:Công_ty_Việt_Nam,
        vn-res:Hoàn_toàn_không_có_nguồn_tham_khảo,
        vn-res:Nhãn_hiệu_thời_trang_cao_cấp,
        vn-res:Pages_using_deprecated_image_syntax,
        vn-res:Sơ_khai_Việt_Nam,
        vn-res:Tất_cả_bài_viết_cần_được_wiki_hóa,
        vn-res:Tất_cả_bài_viết_sơ_khai ;
    prov:wasDerivedFrom [ a prov:Entity ;
            prov:generatedAtTime "2025-09-25T11:53:40.480477"^^xsd:dateTime ;
            prov:wasAttributedTo <https://vi.wikipedia.org/wiki/Cao_Minh_(nhà_may)> ] .

