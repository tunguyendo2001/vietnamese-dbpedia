vn-res:Lý_Tự_Tiên a vn-ont:Người ;
    rdfs:label "Lý Tự Tiên"@vi ;
    vn-ont:abstract """Lý Tự Tiên (李嗣先, ?-687) là thủ lĩnh cuộc khởi nghĩa tại An Nam chống lại sự đô hộ của nhà Đường năm 687.

"""@vi ;
    vn-ont:category vn-res:Bài_có_hộp_thông_tin_có_tham_số_title,
        vn-res:Khởi_nghĩa_Việt_Nam_thời_Bắc_thuộc_lần_3,
