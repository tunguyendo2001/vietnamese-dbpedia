vn-res:Công_ty_Đầu_tư_Tài_chính_Nhà_nước_Thành_phố_Hồ_Chí_Minh a vn-ont:TổChức ;
    rdfs:label "Công ty Đầu tư Tài chính Nhà nước Thành phố Hồ Chí Minh"@vi ;
    vn-ont:abstract "HFIC là tên viết tắt của Công ty Đầu tư Tài chính Nhà nước Tp.HCM, tống giám đốc là bà Phạm Thị Hồng Hà đồng thời là thành viên HĐTV. HFIC được Ủy ban nhân dân Thành phố Hồ Chí Minh ký quyết định thành lập vào năm 2010."@vi ;
