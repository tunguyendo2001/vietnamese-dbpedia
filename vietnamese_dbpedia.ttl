            prov:wasAttributedTo <https://vi.wikipedia.org/wiki/Lý_Quốc_Sư> ] .

vn-res:Lý_Thúc_Hiến a vn-ont:Người ;
    rdfs:label "Lý Thúc Hiến"@vi ;
    vn-ont:abstract """Lý Thúc Hiến (chữ Hán: 李叔獻, ? - 500?) là một thủ lĩnh địa phương, cát cứ Giao Châu, tự trị với chính quyền phong kiến phương Bắc trong lịch sử Việt Nam thời Bắc thuộc lần 2.

"""@vi ;
