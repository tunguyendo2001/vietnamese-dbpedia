@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix vido: <http://vi.dbpedia.org/ontology/> .

vido: a owl:Ontology ;
    rdfs:label "Vietnamese DBpedia Extended Ontology"@vi ;
    rdfs:comment "Ontology dành cho Vietnamese DBpedia, ánh xạ với DBpedia English và bổ sung khái niệm bản địa."@vi .

# ==========================================
# 1. ÁNH XẠ CÁC CLASS CƠ BẢN (LABEL TIẾNG VIỆT)
# ==========================================

vido:Person a owl:Class ;
    rdfs:label "Nhân vật"@vi ;
    owl:equivalentClass dbo:Person .

vido:MilitaryPerson a owl:Class ;
    rdfs:label "Quân nhân"@vi ;
    rdfs:subClassOf vido:Person ;
    owl:equivalentClass dbo:MilitaryPerson .

vido:Company a owl:Class ;
    rdfs:label "Công ty / Doanh nghiệp"@vi ;
    owl:equivalentClass dbo:Company .

vido:University a owl:Class ;
    rdfs:label "Trường Đại học"@vi ;
    owl:equivalentClass dbo:University .

vido:River a owl:Class ;
    rdfs:label "Sông ngòi"@vi ;
    owl:equivalentClass dbo:River .

vido:PopulatedPlace a owl:Class ;
    rdfs:label "Địa điểm dân cư"@vi ;
    owl:equivalentClass dbo:PopulatedPlace .

vido:Building a owl:Class ;
    rdfs:label "Công trình xây dựng"@vi ;
    owl:equivalentClass dbo:Building .

vido:Lake a owl:Class ;
    rdfs:label "Hồ"@vi ;
    owl:equivalentClass dbo:Lake .

vido:Mountain a owl:Class ;
    rdfs:label "Núi"@vi ;
    owl:equivalentClass dbo:Mountain .

vido:Island a owl:Class ;
    rdfs:label "Đảo"@vi ;
    owl:equivalentClass dbo:Island .

vido:ReligiousBuilding a owl:Class ;
    rdfs:label "Công trình tôn giáo"@vi ;
    owl:equivalentClass dbo:ReligiousBuilding .

vido:Airport a owl:Class ;
    rdfs:label "Sân bay"@vi ;
    owl:equivalentClass dbo:Airport .

vido:Road a owl:Class ;
    rdfs:label "Đường giao thông"@vi ;
    owl:equivalentClass dbo:Road .

vido:Organisation a owl:Class ;
    rdfs:label "Tổ chức"@vi ;
    owl:equivalentClass dbo:Organisation .

vido:MilitaryConflict a owl:Class ;
    rdfs:label "Xung đột quân sự"@vi ;
    owl:equivalentClass dbo:MilitaryConflict .

vido:WorldHeritageSite a owl:Class ;
    rdfs:label "Di sản thế giới"@vi ;
    owl:equivalentClass dbo:WorldHeritageSite .

vido:MusicalArtist a owl:Class ;
    rdfs:label "Nghệ sĩ âm nhạc"@vi ;
    rdfs:subClassOf vido:Person ;
    owl:equivalentClass dbo:MusicalArtist .

# ==========================================
# 2. CÁC CLASS ĐẶC THÙ CỦA VIỆT NAM (CUSTOM CLASSES)
# ==========================================

vido:AdministrativeDivisionVN a owl:Class ;
    rdfs:label "Đơn vị hành chính Việt Nam"@vi ;
    rdfs:subClassOf dbo:PopulatedPlace ;
    rdfs:comment "Phân cấp hành chính đặc thù của Việt Nam (Tỉnh, Huyện, Xã)"@vi .

vido:VietnameseProvince a owl:Class ;
    rdfs:label "Tỉnh / Thành phố trực thuộc Trung ương"@vi ;
    rdfs:subClassOf vido:AdministrativeDivisionVN ;
    rdfs:comment "63 tỉnh thành của Việt Nam"@vi .

vido:VietnameseDistrict a owl:Class ;
    rdfs:label "Quận / Huyện / Thị xã"@vi ;
    rdfs:subClassOf vido:AdministrativeDivisionVN ;
    rdfs:comment "Cấp hành chính quận, huyện, thị xã, thành phố thuộc tỉnh"@vi .

vido:VietnameseDynasty a owl:Class ;
    rdfs:label "Triều đại Việt Nam"@vi ;
    rdfs:subClassOf dbo:HistoricalPeriod ;
    rdfs:comment "Các triều đại phong kiến trong lịch sử Việt Nam (Lý, Trần, Lê...)"@vi .

vido:NationalHero a owl:Class ;
    rdfs:label "Anh hùng dân tộc Việt Nam"@vi ;
    rdfs:subClassOf vido:Person ;
    rdfs:comment "Các nhân vật được công nhận là anh hùng dân tộc Việt Nam"@vi .

# ==========================================
# 3. CÁC PROPERTY ĐẶC THÙ HOẶC CẦN VIỆT HÓA
# ==========================================

vido:foundingYear a owl:DatatypeProperty ;
    rdfs:label "năm thành lập"@vi ;
    owl:equivalentProperty dbo:foundingYear ;
    rdfs:range xsd:gYear .

vido:dissolutionYear a owl:DatatypeProperty ;
    rdfs:label "năm sụp đổ / kết thúc"@vi ;
    owl:equivalentProperty dbo:dissolutionYear ;
    rdfs:domain vido:VietnameseDynasty ;
    rdfs:range xsd:gYear .

vido:province a owl:ObjectProperty ;
    rdfs:label "thuộc tỉnh"@vi ;
    owl:equivalentProperty dbo:province ;
    rdfs:domain vido:AdministrativeDivisionVN ;
    rdfs:range dbo:PopulatedPlace .

vido:ethnicGroup a owl:ObjectProperty ;
    rdfs:label "dân tộc"@vi ;
    rdfs:comment "Dân tộc của nhân vật hoặc cộng đồng"@vi ;
    rdfs:range dbo:EthnicGroup .

vido:dynastyEra a owl:ObjectProperty ;
    rdfs:label "triều đại"@vi ;
    rdfs:comment "Triều đại mà nhân vật phong kiến thuộc về"@vi ;
    rdfs:domain vido:Person ;
    rdfs:range vido:VietnameseDynasty .

vido:administrativeLevel a owl:DatatypeProperty ;
    rdfs:label "cấp hành chính"@vi ;
    rdfs:comment "Cấp hành chính (tỉnh, huyện, xã)"@vi ;
    rdfs:domain vido:AdministrativeDivisionVN ;
    rdfs:range xsd:string .
    