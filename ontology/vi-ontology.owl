<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:dbo="http://dbpedia.org/ontology/"
         xmlns:vido="http://vi.dbpedia.org/ontology/">

  <owl:Ontology rdf:about="http://vi.dbpedia.org/ontology/">
    <rdfs:label xml:lang="vi">Vietnamese DBpedia Core Ontology</rdfs:label>
  </owl:Ontology>

  <owl:Class rdf:about="http://vi.dbpedia.org/ontology/Person">
    <rdfs:label xml:lang="vi">Nhân vật</rdfs:label>
    <owl:equivalentClass rdf:resource="http://dbpedia.org/ontology/Person"/>
  </owl:Class>

  <owl:Class rdf:about="http://vi.dbpedia.org/ontology/Organization">
    <rdfs:label xml:lang="vi">Tổ chức</rdfs:label>
    <owl:equivalentClass rdf:resource="http://dbpedia.org/ontology/Organisation"/>
  </owl:Class>

  <owl:DatatypeProperty rdf:about="http://vi.dbpedia.org/ontology/birthDate">
    <rdfs:label xml:lang="vi">ngày sinh</rdfs:label>
    <owl:equivalentProperty rdf:resource="http://dbpedia.org/ontology/birthDate"/>
  </owl:DatatypeProperty>
</rdf:RDF>
