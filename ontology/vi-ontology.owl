<?xml version="1.0"?>
<rdf:RDF xmlns="http://vi.dbpedia.org/ontology/"
     xml:base="http://vi.dbpedia.org/ontology/"
     xmlns:dbo="http://dbpedia.org/ontology/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:vido="http://vi.dbpedia.org/ontology/">
    <owl:Ontology rdf:about="http://vi.dbpedia.org/ontology/">
        <owl:imports rdf:resource="http://dbpedia.org/ontology/"/>
        <rdfs:label xml:lang="en">Vietnamese DBpedia Ontology</rdfs:label>
        <rdfs:label xml:lang="vi">Bản mẫu Ontology DBpedia Tiếng Việt</rdfs:label>
    </owl:Ontology>

    <owl:Class rdf:about="http://vi.dbpedia.org/ontology/VietnameseDynasty">
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/HistoricalPeriod"/>
        <rdfs:label xml:lang="en">Vietnamese Dynasty</rdfs:label>
        <rdfs:label xml:lang="vi">Triều đại Việt Nam</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://vi.dbpedia.org/ontology/AdministrativeDivisionVN">
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/AdministrativeRegion"/>
        <rdfs:label xml:lang="en">Vietnamese Administrative Division</rdfs:label>
        <rdfs:label xml:lang="vi">Đơn vị hành chính Việt Nam</rdfs:label>
    </owl:Class>

    <owl:DatatypeProperty rdf:about="http://vi.dbpedia.org/ontology/templeName">
        <rdfs:domain rdf:resource="http://dbpedia.org/ontology/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">temple name</rdfs:label>
        <rdfs:label xml:lang="vi">miếu hiệu</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://vi.dbpedia.org/ontology/posthumousName">
        <rdfs:domain rdf:resource="http://dbpedia.org/ontology/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">posthumous name</rdfs:label>
        <rdfs:label xml:lang="vi">thụy hiệu</rdfs:label>
    </owl:DatatypeProperty>
</rdf:RDF>
